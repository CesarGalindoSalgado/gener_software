# Copia este archivo a .env (functions/.env está en .gitignore) y llena los valores.
# En producción, usa Secret Manager (firebase functions:secrets:set NOMBRE).

# API del LLM (cerebro de Portteo)
ANTHROPIC_API_KEY=

# Servicio de sesión de WhatsApp (número propio operado por el equipo)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
# Token que el servicio de sesión debe mandar en el header del webhook (lo defines tú)
WHATSAPP_WEBHOOK_SECRET=

# Telegram (respaldo)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google Drive (service account) — fase 2
DRIVE_SERVICE_ACCOUNT_JSON=
