# Variables de entorno del bot de WhatsApp (Portteo).
# Copia este archivo a `.env` y rellena los valores reales.
# NO subas `.env` al repo (ya está en .gitignore).

# URL del Cloud Function webhookWhatsapp (PRODUCCION):
WEBHOOK_URL=https://us-central1-gener-3ecc1.cloudfunctions.net/webhookWhatsapp

# Secreto compartido con la funcion. Copialo TAL CUAL del bot/.env que ya usas
# en tu PC (es el mismo que espera la Cloud Function).
WHATSAPP_WEBHOOK_SECRET=pon-aqui-el-mismo-secreto

# Carpeta de la sesion de WhatsApp. Dejalo en 'auth' para produccion.
# (El entorno de pruebas usa AUTH_DIR=auth-pruebas en su propio .env.pruebas.)
AUTH_DIR=auth
