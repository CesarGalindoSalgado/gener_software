rules_version = '2';

// Principio: los clientes web (Porttea-Gener) solo LEEN; toda escritura pasa por
// Cloud Functions (Admin SDK), donde se validan roles y transacciones (folio).
// La identidad web es el correo (Firebase Auth email/password); el doc de
// usuario usa el correo como id. El teléfono es identidad del bot, no de la web.
service cloud.firestore {
  match /databases/{database}/documents {

    function correo() {
      return request.auth != null ? request.auth.token.email : '';
    }

    function docUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(correo())).data;
    }

    function usuarioActivo() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(correo()))
        && docUsuario().activo == true;
      // TODO producción: exigir también docUsuario().correo == correo() y
      // request.auth.token.email_verified == true (blinda contra registrar un
      // correo del whitelist sin acceso a su bandeja). Se activa cuando el alta
      // de usuarios la haga el Admin SDK creando cuentas ya verificadas.
    }

    function rol() {
      return docUsuario().rol;
    }

    // superAdmin: administrador técnico, por encima del dueño.
    function esAdmin() {
      return usuarioActivo() && rol() in ['superAdmin', 'dueno'];
    }
    function esOperador() {
      return usuarioActivo() && rol() in ['superAdmin', 'dueno', 'secretaria'];
    }

    // Cada usuario puede leer SU PROPIO doc (para descubrir su rol al entrar).
    // Admin (superAdmin/dueño) puede leer todos (lista de usuarios en el portal).
    match /usuarios/{correoDoc} {
      allow read: if request.auth != null
        && (request.auth.token.email == correoDoc || esAdmin());
      allow write: if false; // altas/bajas por backend (Admin SDK)
    }

    // Dominio de cotizaciones: operadores (superAdmin/dueño/secretaria) leen
    match /clientes/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /cotizaciones/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /plantillas/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /precios_historicos/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }

    // Recordatorios: solo administración (superAdmin/dueño)
    match /recordatorios/{doc=**} {
      allow read: if esAdmin();
      allow write: if false;
    }

    // Estado del sistema (ej. conexión de WhatsApp): admin lee; escribe el backend
    match /sistema/{doc=**} {
      allow read: if esAdmin();
      allow write: if false;
    }

    // ---- Módulo de Rutinas: operadores (superAdmin/dueño/secretaria) leen ----
    // Todo se escribe por Cloud Functions (Admin SDK). El técnico opera por
    // WhatsApp, no lee desde la web.
    match /sedes/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /equipos/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /rutinas_plantilla/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /rutinas_ejecucion/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }
    match /oportunidades/{doc=**} {
      allow read: if esOperador();
      allow write: if false;
    }

    // Contadores de folio: nunca accesibles desde el cliente
    match /counters/{doc=**} {
      allow read, write: if false;
    }
  }
}
