rules_version = '2';

// Principio: los clientes web (Porttea-Gener) solo LEEN; toda escritura pasa por
// Cloud Functions (Admin SDK), donde se validan roles y transacciones (folio).
// La identidad es el número de teléfono (Firebase Auth phone sign-in).
service cloud.firestore {
  match /databases/{database}/documents {

    // Identidad web: el correo del login con Google (Gmail). El doc de usuario
    // usa el correo como id. El teléfono es identidad del bot, no de la web.
    function correo() {
      return request.auth.token.email;
    }

    function usuarioActivo() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/usuarios/$(correo()))
        && get(/databases/$(database)/documents/usuarios/$(correo())).data.activo == true;
    }

    function rol() {
      return get(/databases/$(database)/documents/usuarios/$(correo())).data.rol;
    }

    // Dueño y secretaria pueden leer el dominio de cotizaciones
    match /clientes/{doc=**} {
      allow read: if usuarioActivo() && rol() in ['dueno', 'secretaria'];
      allow write: if false;
    }
    match /cotizaciones/{doc=**} {
      allow read: if usuarioActivo() && rol() in ['dueno', 'secretaria'];
      allow write: if false;
    }
    match /plantillas/{doc=**} {
      allow read: if usuarioActivo() && rol() in ['dueno', 'secretaria'];
      allow write: if false;
    }
    match /precios_historicos/{doc=**} {
      allow read: if usuarioActivo() && rol() in ['dueno', 'secretaria'];
      allow write: if false;
    }

    // Solo el dueño ve sus recordatorios y la lista de usuarios
    match /recordatorios/{doc=**} {
      allow read: if usuarioActivo() && rol() == 'dueno';
      allow write: if false;
    }
    match /usuarios/{doc=**} {
      allow read: if usuarioActivo() && rol() == 'dueno';
      allow write: if false;
    }

    // Contadores de folio: nunca accesibles desde el cliente
    match /counters/{doc=**} {
      allow read, write: if false;
    }
  }
}
